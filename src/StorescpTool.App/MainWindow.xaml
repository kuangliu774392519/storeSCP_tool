<Window x:Class="StorescpTool.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="StoreSCP 现场联调工具"
        Height="860"
        Width="1320"
        MinHeight="800"
        MinWidth="1220">
    <Grid Background="#F3F6FB">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="#17324D" Padding="20">
            <StackPanel>
                <TextBlock FontSize="24" FontWeight="Bold" Foreground="White" Text="DICOM StoreSCP 现场联调工具" />
                <TextBlock Margin="0,6,0,0" Foreground="#D5E0EA" Text="用于现场验证 CT 推送、网络连通性、C-ECHO 和本机 C-STORE 自测的 Windows 调试工具" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1.55*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,10,0">
                    <Border Padding="16" Margin="0,0,0,12" Background="White" CornerRadius="10">
                        <StackPanel>
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="StoreSCP 监听" />
                            <UniformGrid Margin="0,12,0,0" Columns="2">
                                <StackPanel Margin="0,0,12,8">
                                    <TextBlock Text="本地 AE Title" />
                                    <TextBox Text="{Binding LocalAeTitle, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,12,8">
                                    <TextBlock Text="监听 IP" />
                                    <DockPanel LastChildFill="True">
                                        <Button Width="64"
                                                Margin="8,0,0,0"
                                                DockPanel.Dock="Right"
                                                Padding="8,4"
                                                Command="{Binding RefreshLocalAddressesCommand}"
                                                Content="刷新" />
                                        <ComboBox IsEditable="True"
                                                  ItemsSource="{Binding AvailableListenIps}"
                                                  Text="{Binding ListenIp, UpdateSourceTrigger=PropertyChanged}" />
                                    </DockPanel>
                                </StackPanel>
                                <StackPanel Margin="0,0,12,8">
                                    <TextBlock Text="监听端口" />
                                    <TextBox Text="{Binding ListenPort, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,12,8">
                                    <TextBlock Text="接收目录" />
                                    <TextBox Text="{Binding ReceiveDirectory, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,12,8">
                                    <TextBlock Text="日志目录" />
                                    <TextBox Text="{Binding LogDirectory, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </UniformGrid>

                            <CheckBox Margin="0,4,0,0" Content="校验 Called AE" IsChecked="{Binding ValidateCalledAe}" />
                            <TextBlock Margin="0,10,0,0" Foreground="#35516B" Text="{Binding StoreScpStatus, StringFormat=当前状态: {0}}" />
                            <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Foreground="#35516B" Text="{Binding OperationMessage, StringFormat=操作提示: {0}}" />
                            <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Foreground="#5A748B" Text="{Binding LocalAddresses, StringFormat=本机 IPv4: {0}}" />
                            <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Foreground="#5A748B" Text="{Binding CurrentLogFilePath, StringFormat=当前日志文件: {0}}" />

                            <StackPanel Margin="0,14,0,0" Orientation="Horizontal">
                                <Button Width="120" Margin="0,0,10,0" Padding="10,6" Command="{Binding StartStoreScpCommand}" Content="启动监听" />
                                <Button Width="120" Margin="0,0,10,0" Padding="10,6" Command="{Binding StopStoreScpCommand}" Content="停止监听" />
                                <Button Width="120" Padding="10,6" Command="{Binding SaveConfigCommand}" Content="保存配置" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Padding="16" Margin="0,0,0,12" Background="White" CornerRadius="10">
                        <StackPanel>
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="网络与 DICOM 调试" />
                            <TextBlock Margin="0,12,0,6" FontWeight="SemiBold" Text="Ping" />
                            <DockPanel>
                                <TextBox Width="280" Margin="0,0,10,0" Text="{Binding PingHost, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Width="110" Command="{Binding PingCommand}" Content="执行 Ping" />
                            </DockPanel>

                            <TextBlock Margin="0,12,0,6" FontWeight="SemiBold" Text="TCP 端口检测" />
                            <DockPanel>
                                <TextBox Width="200" Margin="0,0,10,0" Text="{Binding TcpHost, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Width="80" Margin="0,0,10,0" Text="{Binding TcpPort, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Width="110" Command="{Binding CheckPortCommand}" Content="检测端口" />
                            </DockPanel>

                            <TextBlock Margin="0,12,0,6" FontWeight="SemiBold" Text="DICOM C-ECHO" />
                            <UniformGrid Columns="2">
                                <TextBox Margin="0,0,10,8" Text="{Binding EchoHost, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Margin="0,0,10,8" Text="{Binding EchoPort, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Margin="0,0,10,8" Text="{Binding EchoCallingAeTitle, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Margin="0,0,10,8" Text="{Binding EchoCalledAeTitle, UpdateSourceTrigger=PropertyChanged}" />
                            </UniformGrid>

                            <StackPanel Orientation="Horizontal">
                                <Button Width="120" Margin="0,0,10,0" Command="{Binding EchoCommand}" Content="执行 C-ECHO" />
                                <Button Width="140" Command="{Binding SelfTestStoreCommand}" Content="执行本机 C-STORE 自测" />
                            </StackPanel>

                            <Border Margin="0,14,0,0" Padding="12" Background="#F7FAFD" CornerRadius="8">
                                <TextBlock TextWrapping="Wrap" Text="{Binding NetworkResult}" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Padding="16" Margin="0,0,0,12" Background="White" CornerRadius="10">
                        <StackPanel>
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="诊断导出" />
                            <TextBlock Margin="0,12,0,0" TextWrapping="Wrap" Foreground="#5A748B" Text="导出当前日志、配置快照、接收记录和会话统计，便于现场问题反馈。" />
                            <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                                <Button Width="140" Command="{Binding ExportDiagnosticsCommand}" Content="导出诊断包" />
                            </StackPanel>
                            <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" Foreground="#35516B" Text="{Binding DiagnosticBundlePath, StringFormat=最近导出目录: {0}}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="1" Margin="10,0,0,0" Padding="12" Background="White" CornerRadius="10">
                <TabControl>
                    <TabItem Header="会话统计">
                        <ListView Margin="8" ItemsSource="{Binding ReceiveSessions}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Width="70" Header="状态" DisplayMemberBinding="{Binding Status}" />
                                    <GridViewColumn Width="130" Header="开始时间" DisplayMemberBinding="{Binding StartTime, StringFormat=yyyy-MM-dd HH:mm:ss}" />
                                    <GridViewColumn Width="130" Header="结束时间" DisplayMemberBinding="{Binding EndTime, StringFormat=yyyy-MM-dd HH:mm:ss}" />
                                    <GridViewColumn Width="85" Header="Calling AE" DisplayMemberBinding="{Binding CallingAe}" />
                                    <GridViewColumn Width="100" Header="远端 IP" DisplayMemberBinding="{Binding RemoteIp}" />
                                    <GridViewColumn Width="60" Header="数量" DisplayMemberBinding="{Binding ReceivedCount}" />
                                    <GridViewColumn Width="200" Header="最后文件" DisplayMemberBinding="{Binding LastFilePath}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </TabItem>

                    <TabItem Header="接收记录">
                        <ListView Margin="8" ItemsSource="{Binding ReceiveRecords}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Width="130" Header="时间" DisplayMemberBinding="{Binding ReceivedAt, StringFormat=yyyy-MM-dd HH:mm:ss}" />
                                    <GridViewColumn Width="90" Header="Calling AE" DisplayMemberBinding="{Binding CallingAe}" />
                                    <GridViewColumn Width="110" Header="远端 IP" DisplayMemberBinding="{Binding RemoteIp}" />
                                    <GridViewColumn Width="120" Header="患者" DisplayMemberBinding="{Binding PatientName}" />
                                    <GridViewColumn Width="180" Header="Study UID" DisplayMemberBinding="{Binding StudyInstanceUid}" />
                                    <GridViewColumn Width="240" Header="文件" DisplayMemberBinding="{Binding FilePath}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </TabItem>

                    <TabItem Header="实时日志">
                        <ListBox Margin="8" ItemsSource="{Binding Logs}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="6" Margin="0,0,0,6" Background="#F8FAFC" CornerRadius="6">
                                        <TextBlock TextWrapping="Wrap">
                                            <Run Text="{Binding Timestamp, StringFormat=HH:mm:ss}" />
                                            <Run Text="  " />
                                            <Run Text="{Binding Level}" />
                                            <Run Text="  " />
                                            <Run Text="{Binding Module}" />
                                            <Run Text="  " />
                                            <Run Text="{Binding Message}" />
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </Grid>
</Window>
